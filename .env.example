# ══════════════════════════════════════════════
# Agentic AI Trader — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables are optional. The app will use
# sensible defaults if they are not set.
# ══════════════════════════════════════════════

# Flask secret key (generate a random one for production)
# python -c "import os; print(os.urandom(24).hex())"
SECRET_KEY=

# Server port (default: 5008)
PORT=5008

# Debug mode (set to False in production)
DEBUG=False

# NewsAPI Configuration for Market News & Sentiment Analysis
NEWS_API_KEY=

# AlphaVantage Configuration for fallback market data
ALPHA_VANTAGE_API_KEY=
